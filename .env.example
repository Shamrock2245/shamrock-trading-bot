# ─────────────────────────────────────────────────────────────────────────────
# Shamrock Trading Bot — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. It is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Trading Mode ─────────────────────────────────────────────────────────────
# paper = simulate trades only (no real funds moved)
# live  = real execution (⚠️ only after thorough paper testing)
MODE=paper

# ── EVM Wallet Private Keys (NEVER hardcode — use env vars only) ──────────────
# Primary wallet: gem sniping & active positions
WALLET_PRIVATE_KEY_PRIMARY=your_primary_wallet_private_key_here

# Wallet B: DCA & mean-reversion strategies
WALLET_PRIVATE_KEY_B=your_wallet_b_private_key_here

# Wallet C: long-term holds & profit sweeps (cold storage)
WALLET_PRIVATE_KEY_C=your_wallet_c_private_key_here

# ── Solana Wallet Keys (base58-encoded keypairs) ──────────────────────────────
# Primary Solana wallet (used for Solana gem sniping via Jupiter)
SOLANA_PRIVATE_KEY_PRIMARY=your_solana_primary_base58_private_key_here

# Wallet B Solana key (optional — for DCA on Solana)
SOLANA_PRIVATE_KEY_B=your_solana_b_base58_private_key_here

# Wallet C Solana key (optional — cold reserve on Solana)
SOLANA_PRIVATE_KEY_C=your_solana_c_base58_private_key_here

# ── EVM Wallet Public Addresses (safe to reference) ───────────────────────────
WALLET_ADDRESS_PRIMARY=0x3eb320fad3f51fe4f2a4531f911ef56694346eef
WALLET_ADDRESS_B=0x0835eb8447f3ac90351951bb5d22e77afd9b81c0
WALLET_ADDRESS_C=0x32a71a0b8f10f263cd5d3fd8802fd9683ae6c860

# ── Solana Wallet Public Addresses (base58) ───────────────────────────────────
# Your Solana wallet public keys (safe to reference)
SOLANA_ADDRESS_PRIMARY=your_solana_primary_public_key_here
SOLANA_ADDRESS_B=your_solana_b_public_key_here
SOLANA_ADDRESS_C=your_solana_c_public_key_here

# ── EVM RPC Endpoints ─────────────────────────────────────────────────────────
# Ethereum (use Alchemy/Infura for reliability — free tier available)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
ETH_RPC_FALLBACK=https://cloudflare-eth.com

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_FALLBACK=https://base.publicnode.com

# Arbitrum
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
ARB_RPC_FALLBACK=https://arbitrum.publicnode.com

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_FALLBACK=https://polygon.publicnode.com

# BSC
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_RPC_FALLBACK=https://bsc.publicnode.com

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Use a dedicated RPC for speed (Helius, QuickNode, or Triton recommended)
# Free public RPC: https://api.mainnet-beta.solana.com (rate-limited)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Helius (recommended for production): https://rpc.helius.xyz/?api-key=YOUR_KEY
# SOLANA_RPC_URL=https://rpc.helius.xyz/?api-key=your_helius_api_key

# ── Jupiter Aggregator (Solana DEX routing) ───────────────────────────────────
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ── MEV Protection ────────────────────────────────────────────────────────────
# Flashbots relay endpoint (Ethereum mainnet)
FLASHBOTS_RPC_URL=https://rpc.flashbots.net
# Flashbots signing key (separate from trading keys — used to sign bundles)
FLASHBOTS_SIGNING_KEY=your_flashbots_signing_key_here

# CoW Protocol (MEV-protected swaps via batch auctions)
COW_API_URL=https://api.cow.fi/mainnet

# ── DEX API Keys ──────────────────────────────────────────────────────────────
# 1inch Aggregation API
ONEINCH_API_KEY=your_1inch_api_key_here
ONEINCH_API_URL=https://api.1inch.dev/swap/v6.0

# ── Data Provider API Keys ────────────────────────────────────────────────────
# CoinMarketCap
CMC_API_KEY=your_coinmarketcap_api_key_here

# CoinGecko (leave blank for free tier)
COINGECKO_API_KEY=

# Etherscan (and compatible explorers)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Moralis
MORALIS_API_KEY=your_moralis_api_key_here

# Token Sniffer
TOKEN_SNIFFER_API_KEY=your_tokensniffer_api_key_here

# LunarCrush (social sentiment — free tier: 100 req/day)
# Sign up at: https://lunarcrush.com/developers
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# GoPlus Security API (token safety checks — free tier)
# No key required for free tier: https://gopluslabs.io/
GOPLUS_API_KEY=

# ── Smart Money Tracking ──────────────────────────────────────────────────────
# Comma-separated list of known profitable wallet addresses to track
# These are checked against token holders to score smart money overlap
# Example: Alex Becker's known trading wallets, top Zerion wallets, etc.
SMART_MONEY_WALLETS=0x3eb320fad3f51fe4f2a4531f911ef56694346eef,0x0835eb8447f3ac90351951bb5d22e77afd9b81c0

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack webhook URL (create at api.slack.com/apps)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/here
SLACK_CHANNEL_TRADES=#shamrock-trades
SLACK_CHANNEL_ALERTS=#shamrock-alerts

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Risk Management Parameters ────────────────────────────────────────────────
# Maximum % of wallet to risk per trade
MAX_POSITION_SIZE_PERCENT=2.0

# Maximum concurrent open positions per wallet
MAX_CONCURRENT_POSITIONS=10

# Trailing stop-loss from peak price (%) — activated after TP1
STOP_LOSS_PERCENT=20.0

# Hard stop-loss from entry price (%)
HARD_STOP_LOSS_PERCENT=25.0

# Take-profit levels (multipliers from entry)
# TP1 at 2x → sell 40% | TP2 at 5x → sell 35% | TP3 at 10x → sell 20%
TAKE_PROFIT_1_MULTIPLIER=2.0
TAKE_PROFIT_2_MULTIPLIER=5.0
TAKE_PROFIT_3_MULTIPLIER=10.0

# Circuit breaker: halt all trading if portfolio drops this % in 24h
CIRCUIT_BREAKER_PERCENT=15.0

# Daily loss limit per wallet (in ETH)
DAILY_LOSS_LIMIT_ETH=0.5

# Maximum gas price (gwei) — skip trades above this
MAX_GAS_GWEI=50

# Minimum ETH balance alert threshold (can't pay gas below this)
MIN_ETH_BALANCE_ALERT=0.05

# ── Scanner Settings ──────────────────────────────────────────────────────────
# How often to run the gem scanner (seconds)
SCAN_INTERVAL_SECONDS=60

# Minimum gem score to consider (0-100)
# Lowered from 65 to 55 to catch more early gems
MIN_GEM_SCORE=55

# Express lane threshold — skip TA, execute immediately (score ≥ this)
EXPRESS_LANE_SCORE=82

# Minimum liquidity in USD
MIN_LIQUIDITY_USD=50000

# Maximum token age to consider (hours)
MAX_TOKEN_AGE_HOURS=168

# Active chains to scan (comma-separated)
# Options: ethereum, base, arbitrum, polygon, bsc, solana
ACTIVE_CHAINS=ethereum,base,arbitrum,polygon,bsc,solana

# ── Position Monitor ──────────────────────────────────────────────────────────
# How often to check open positions for TP/SL (seconds)
POSITION_CHECK_INTERVAL_SECONDS=30

# Output files for position persistence
POSITIONS_FILE=output/positions.json
TRADES_FILE=output/trades.json

# ── Conviction-Based Position Sizing ─────────────────────────────────────────
# Score thresholds for position size multipliers
CONVICTION_HIGH_THRESHOLD=82   # Express lane: 100% of max size
CONVICTION_MID_THRESHOLD=70    # Strong signal: 75% of max size
# Below 70: 50% of max size

CONVICTION_HIGH_MULTIPLIER=1.0
CONVICTION_MID_MULTIPLIER=0.75
CONVICTION_LOW_MULTIPLIER=0.5

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/shamrock_trading.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
